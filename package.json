{
  "name": "@myobie/coord",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Node port of the coord file-folder coordination CLI + embeddable TypeScript API.",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "bin": {
    "st": "./bin/st",
    "smalltalk": "./bin/smalltalk",
    "coord": "./bin/coord"
  },
  "files": [
    "bin/",
    "src/",
    "CHANGELOG.md",
    "LAYOUT.md",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.examples.json",
    "example:tui-watch": "node --experimental-strip-types examples/tui-watch.ts"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "@myobie/pty": "file:../pty",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "zod": "^4.4.3"
  }
}
