#!/usr/bin/env bash
# coord — Node entry point.
#
# Per brief-006 task 12, the bash CLI has been replaced by the Node port.
# This shim execs `node --experimental-strip-types` against src/cli.ts so
# the TypeScript runs natively without a build step.

set -euo pipefail

# Resolve any symlink chain (including the `npm link` indirection) to the
# real bin/coord, then walk one level up to the repo root. macOS doesn't
# ship `readlink -f`, so do it the portable way: at each step, treat the
# readlink target as relative-to-the-symlink-dir unless it's absolute.
COORD_BIN="${BASH_SOURCE[0]}"
while [ -L "$COORD_BIN" ]; do
  COORD_DIR="$(cd "$(dirname "$COORD_BIN")" && pwd)"
  TARGET="$(readlink "$COORD_BIN")"
  case "$TARGET" in
    /*) COORD_BIN="$TARGET" ;;
    *)  COORD_BIN="$COORD_DIR/$TARGET" ;;
  esac
done
COORD_REPO="$(cd "$(dirname "$COORD_BIN")/.." && pwd)"

exec node --experimental-strip-types "$COORD_REPO/src/cli.ts" "$@"
