#!/usr/bin/env bash
# coord — back-compat alias for `st`. brief-005-phase0.
#
# Existing `.mcp.json` files point at `bin/coord`; this file stays at
# the same path so they continue to resolve. It captures the invoked
# name ("coord") into the env var the node entry checks, then chains
# to the real `bin/st` shim. The next shim sees `_ST_INVOKED_AS`
# already set and keeps it.
#
# Phase 5 (much later, after every agent's config has migrated to
# `bin/st`) is when this alias gets dropped.

set -euo pipefail

export _ST_INVOKED_AS="${_ST_INVOKED_AS:-$(basename "$0")}"

# Walk the symlink chain to find the real bin/coord in the package
# dir, then exec the sibling `bin/st`. Required for `npm link`, where
# the global `coord` is a symlink chain into the package's bin/, and
# `bin/st` is NOT necessarily linked into the same global directory.
COORD_BIN="${BASH_SOURCE[0]}"
while [ -L "$COORD_BIN" ]; do
  COORD_DIR="$(cd "$(dirname "$COORD_BIN")" && pwd)"
  TARGET="$(readlink "$COORD_BIN")"
  case "$TARGET" in
    /*) COORD_BIN="$TARGET" ;;
    *)  COORD_BIN="$COORD_DIR/$TARGET" ;;
  esac
done
COORD_DIR="$(cd "$(dirname "$COORD_BIN")" && pwd)"
exec "$COORD_DIR/st" "$@"
